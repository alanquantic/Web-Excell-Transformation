# ------------------------------------------------------------------
# Eagle OTR Ops Suite — environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ------------------------------------------------------------------

# PostgreSQL connection — Neon, Vercel Postgres, Supabase, etc.
#
# DATABASE_URL: pooled connection used by the app at runtime (Vercel serverless).
#   For Neon, use the "-pooler" host and add pgbouncer=true.
# DIRECT_URL:  direct (non-pooled) connection used by Prisma for migrations / db push.
#   For Neon, the same host WITHOUT "-pooler".
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/DBNAME?sslmode=require"

# NextAuth session-encryption secret.
# Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-secret"

# Canonical URL of the deployment (required by NextAuth in production).
# Local dev:  http://localhost:3000
# Vercel:     https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"
