# ------------------------------------------------------------------
# Eagle OTR Ops Suite — environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ------------------------------------------------------------------

# PostgreSQL connection string.
# Providers: Neon, Vercel Postgres, Supabase, Railway, etc.
# Example (Neon): postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# NextAuth session-encryption secret.
# Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-secret"

# Canonical URL of the deployment (required by NextAuth in production).
# Local dev:  http://localhost:3000
# Vercel:     https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"
